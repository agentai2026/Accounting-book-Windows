## 模型规范（强制执行）

```dart
// 所有模型必须：
// 1. 使用 freezed 生成不可变对象
// 2. 实现 toJson / fromJson
// 3. 包含 uuid + updatedAt + deletedAt
// 4. 金额字段用 int（分）

import 'package:freezed_annotation/freezed_annotation.dart';

part 'transaction.freezed.dart';
part 'transaction.g.dart';

@freezed
class Transaction with _$Transaction {
  const factory Transaction({
    int? id,                    // 本地自增ID，不参与同步
    required String uuid,       // ⭐ 全局唯一，跨设备不变
    required int bookId,
    required TransactionType type,
    required int amount,        // ⭐ 单位：分
    required int categoryId,
    int? fromAccountId,
    int? toAccountId,
    required DateTime date,
    String? description,
    List<String>? images,       // 相对路径
    String? location,
    @Default(false) bool isReimbursable,
    @Default(false) bool isScheduled,
    required DateTime createdAt,
    required DateTime updatedAt,  // ⭐ 同步冲突判断依据
    DateTime? deletedAt,         // ⭐ 软删除
  }) = _Transaction;

  factory Transaction.fromJson(Map<String, dynamic> json) =>
      _$TransactionFromJson(json);
}
```

