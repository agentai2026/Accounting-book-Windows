    failure: (error) => showSnackBar(context, error.message),
  );
});
```

### 数据库操作
```dart
// 所有数据库操作必须 try-catch 并记录日志
// ✅
try {
  await db.transaction((txn) async {
    // ...
  });
} catch (e, stack) {
  _logger.e('数据库事务失败', error: e, stackTrace: stack);
  rethrow;
}
