## 数据库 Schema 规范（强制执行）

### 核心原则
- 所有业务实体必须有 `uuid`（全局唯一，跨设备不变）+ `updated_at` + `deleted_at`（软删除）
- 本地自增 `id` 仅用于本机关联查询，不参与同步
- 金额存储单位为**分**，类型为 `INTEGER`，禁止用 `REAL/double`
- 迁移版本号从 1 开始，只增不改，不可逆

### 完整 DDL

```sql
-- ==================== 账本 ====================
CREATE TABLE books (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  uuid TEXT NOT NULL UNIQUE,
  name TEXT NOT NULL,
  color TEXT DEFAULT '#2196F3',
  sort_order INTEGER DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  deleted_at INTEGER DEFAULT NULL
);
CREATE INDEX idx_books_uuid ON books(uuid);
CREATE INDEX idx_books_updated ON books(updated_at);

-- ==================== 账户 ====================
CREATE TABLE accounts (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  uuid TEXT NOT NULL UNIQUE,
  book_id INTEGER NOT NULL,
  name TEXT NOT NULL,
  type INTEGER NOT NULL,        -- 0:cash 1:alipay 2:wechat 3:bankCard 4:creditCard 5:virtual
  balance INTEGER DEFAULT 0,    -- 单位：分
  currency TEXT DEFAULT 'CNY',
  icon TEXT,
  sort_order INTEGER DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  deleted_at INTEGER DEFAULT NULL,
  FOREIGN KEY (book_id) REFERENCES books(id)
);
CREATE INDEX idx_accounts_uuid ON accounts(uuid);
CREATE INDEX idx_accounts_book ON accounts(book_id);
CREATE INDEX idx_accounts_updated ON accounts(updated_at);

-- ==================== 分类 ====================
CREATE TABLE categories (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  uuid TEXT NOT NULL UNIQUE,
  parent_id INTEGER DEFAULT NULL,
  name TEXT NOT NULL,
  type INTEGER NOT NULL,        -- 0:expense 1:income
  icon TEXT,
  color TEXT,
  sort_order INTEGER DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  deleted_at INTEGER DEFAULT NULL,
  FOREIGN KEY (parent_id) REFERENCES categories(id)
);
CREATE INDEX idx_categories_uuid ON categories(uuid);
CREATE INDEX idx_categories_type ON categories(type);
CREATE INDEX idx_categories_updated ON categories(updated_at);

-- ==================== 标签 ====================
CREATE TABLE tags (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  uuid TEXT NOT NULL UNIQUE,
  name TEXT NOT NULL UNIQUE,
  color TEXT,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  deleted_at INTEGER DEFAULT NULL
);
CREATE INDEX idx_tags_uuid ON tags(uuid);

-- ==================== 账单-标签关联 ====================
CREATE TABLE transaction_tags (
  transaction_id INTEGER NOT NULL,
  tag_id INTEGER NOT NULL,
  PRIMARY KEY (transaction_id, tag_id),
  FOREIGN KEY (transaction_id) REFERENCES transactions(id),
  FOREIGN KEY (tag_id) REFERENCES tags(id)
);

-- ==================== 账单 ====================
CREATE TABLE transactions (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  uuid TEXT NOT NULL UNIQUE,
  book_id INTEGER NOT NULL,
  type INTEGER NOT NULL,        -- 0:expense 1:income 2:transfer
  amount INTEGER NOT NULL,      -- 单位：分，正数
  category_id INTEGER NOT NULL,
  from_account_id INTEGER,      -- 支出/转账转出
  to_account_id INTEGER,        -- 收入/转账转入
  date INTEGER NOT NULL,        -- 时间戳毫秒
  description TEXT,
  images TEXT,                  -- JSON 数组：相对路径
  location TEXT,
  is_reimbursable INTEGER DEFAULT 0,
  is_scheduled INTEGER DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  deleted_at INTEGER DEFAULT NULL,
  FOREIGN KEY (book_id) REFERENCES books(id),
  FOREIGN KEY (category_id) REFERENCES categories(id),
  FOREIGN KEY (from_account_id) REFERENCES accounts(id),
  FOREIGN KEY (to_account_id) REFERENCES accounts(id)
);
CREATE INDEX idx_transactions_uuid ON transactions(uuid);
CREATE INDEX idx_transactions_date ON transactions(date);
CREATE INDEX idx_transactions_book ON transactions(book_id);
CREATE INDEX idx_transactions_category ON transactions(category_id);
CREATE INDEX idx_transactions_updated ON transactions(updated_at);
CREATE INDEX idx_transactions_type ON transactions(type);

-- ==================== 预算 ====================
CREATE TABLE budgets (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  uuid TEXT NOT NULL UNIQUE,
  book_id INTEGER NOT NULL,
  category_id INTEGER,          -- NULL = 全分类预算
  amount INTEGER NOT NULL,      -- 单位：分
  period_type INTEGER NOT NULL, -- 0:monthly 1:yearly 2:custom
  start_date INTEGER,
  end_date INTEGER,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  deleted_at INTEGER DEFAULT NULL,
  FOREIGN KEY (book_id) REFERENCES books(id),
  FOREIGN KEY (category_id) REFERENCES categories(id)
);
CREATE INDEX idx_budgets_uuid ON budgets(uuid);

-- ==================== 周期账单 ====================
CREATE TABLE scheduled_transactions (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  uuid TEXT NOT NULL UNIQUE,
  book_id INTEGER NOT NULL,
  type INTEGER NOT NULL,
  amount INTEGER NOT NULL,
  category_id INTEGER NOT NULL,
  from_account_id INTEGER,
  to_account_id INTEGER,
  description TEXT,
  frequency TEXT NOT NULL,      -- daily/weekly/monthly/yearly
  interval INTEGER DEFAULT 1,
  next_date INTEGER NOT NULL,
  enabled INTEGER DEFAULT 1,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  deleted_at INTEGER DEFAULT NULL,
  FOREIGN KEY (book_id) REFERENCES books(id)
);
CREATE INDEX idx_scheduled_uuid ON scheduled_transactions(uuid);

-- ==================== 借贷 ====================
CREATE TABLE loans (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  uuid TEXT NOT NULL UNIQUE,
  type INTEGER NOT NULL,        -- 0:borrow 1:lend
  person TEXT NOT NULL,
  amount INTEGER NOT NULL,      -- 单位：分
  date INTEGER NOT NULL,
  due_date INTEGER,
  is_repaid INTEGER DEFAULT 0,
  description TEXT,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  deleted_at INTEGER DEFAULT NULL
);
CREATE INDEX idx_loans_uuid ON loans(uuid);

-- ==================== 同步记录 ====================
CREATE TABLE sync_records (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  device_id TEXT NOT NULL,
  device_name TEXT,
  last_sync_at INTEGER NOT NULL,
  sync_type TEXT NOT NULL,      -- push/pull/full
  status INTEGER DEFAULT 0,     -- 0:success 1:failed
  created_at INTEGER NOT NULL
);
CREATE INDEX idx_sync_device ON sync_records(device_id);

-- ==================== 设置 ====================
CREATE TABLE app_settings (
  key TEXT PRIMARY KEY,
  value TEXT,
  updated_at INTEGER NOT NULL
);
```

### 迁移策略
- 版本号存储在 `app_settings` 表中，key = `db_version`
- 启动时检查版本，按顺序执行缺失的迁移脚本
- 迁移脚本必须幂等（可重复执行不报错）
- 禁止修改已发布的迁移脚本，只能新增

